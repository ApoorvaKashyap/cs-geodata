# -----------------------------------------------------------------------
# GeoData Pipeline — environment variable reference
# Copy this file to .env and fill in the values for your environment.
# Variables marked REQUIRED have no default and must be set.
# -----------------------------------------------------------------------

# ---- Redis (REQUIRED) -------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# How long run-progress keys live in Redis (seconds). Default: 7 days.
# REDIS_PROGRESS_TTL_SECONDS=604800

# ---- RQ queues --------------------------------------------------------
# RQ_RUNS_QUEUE=runs
# RQ_FETCH_QUEUE=fetch
# RQ_JOB_TIMEOUT=21600   # 6 hours in seconds

# ---- S3 ---------------------------------------------------------------
# Leave S3_ENDPOINT_URL unset to use the default AWS endpoint.
# S3_ENDPOINT_URL=http://localhost:9000   # MinIO / localstack example

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1

# Default bucket for Descriptor TOMLs when not encoded in the URI.
# S3_DESCRIPTOR_BUCKET=my-pipeline-bucket

# ---- GeoServer / WFS (REQUIRED) ---------------------------------------
GEOSERVER_BASE_URL=https://geoserver.corestack.example.com/geoserver

# WFS_MAX_CONCURRENT_FETCHES=20
# WFS_REQUEST_TIMEOUT_SECONDS=120
# WFS_VERSION=2.0.0

# ---- STAC catalogue ---------------------------------------------------
# STAC_REQUEST_TIMEOUT_SECONDS=30

# ---- DuckDB -----------------------------------------------------------
# DUCKDB_MEMORY_LIMIT=4GB
# DUCKDB_THREADS=4

# ---- Working directories ----------------------------------------------
# RUN_WORKSPACE_ROOT=/tmp/runs

# ---- Logging ----------------------------------------------------------
# LOG_LEVEL=INFO
